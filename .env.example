# Server configuration
PORT=5001
HOST=localhost

# Security token required by AVP CRM to call this gateway
GATEWAY_API_KEY=avp_whatsapp_secure_gateway_token_12345

# CRM Webhook Settings (where the gateway posts back incoming messages and status changes)
CRM_WEBHOOK_URL=http://localhost/avpcrm/avp_whatsapp/webhook
CRM_API_TOKEN=avp_whatsapp_secure_crm_token_54321

# Session path (defaults to ./session if not set)
SESSION_PATH=./session
